{
  "name": "@xiaobaitu/db",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "prisma": "prisma",
    "validate": "DATABASE_URL=postgresql://postgres:postgres@localhost:5432/xiaobaitu prisma validate",
    "generate": "prisma generate",
    "migrate": "prisma migrate dev",
    "migrate:deploy": "prisma migrate deploy",
    "seed:system": "node ./scripts/bootstrap-system-user.mjs",
    "deploy:v1": "pnpm run migrate:deploy && pnpm run generate && pnpm run seed:system"
  },
  "dependencies": {
    "@prisma/client": "5.22.0"
  },
  "devDependencies": {
    "prisma": "5.22.0"
  }
}
