# Web
NEXT_PUBLIC_API_BASE_URL=https://api.your-domain.example.com
NEXTAUTH_URL=https://web.your-domain.example.com
NEXTAUTH_SECRET=replace-with-long-random-secret
CASDOOR_ISSUER=https://casdoor.example.com
CASDOOR_CLIENT_ID=replace-with-casdoor-client-id
CASDOOR_CLIENT_SECRET=replace-with-casdoor-client-secret
TEAM_ADMIN_EMAILS=admin@example.com
TEAM_ALLOWED_EMAIL_DOMAINS=example.com

# API / Worker
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/xiaobaitu
REDIS_URL=redis://redis:6379/0
JOB_STORE_BACKEND=database
ASYNC_JOB_BACKEND=celery
AUTO_BOOTSTRAP_DB=true
API_APP_NAME=XiaoBaiTu API
API_APP_VERSION=1.0.0
SYSTEM_ENCRYPTION_KEY=replace-with-32-byte-key
