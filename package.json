{
  "name": "xiaobaitu-platform",
  "private": true,
  "packageManager": "pnpm@9.12.3",
  "scripts": {
    "dev:web": "pnpm --filter web dev",
    "dev:api": "uvicorn apps.api.main:app --reload --port 8000",
    "build:web": "pnpm --dir apps/web exec next build",
    "lint:web": "pnpm --filter web lint",
    "release:smoke": "python3 scripts/rebuild_release_smoke.py",
    "prisma:validate": "pnpm --filter @xiaobaitu/db validate",
    "prisma:generate": "pnpm --filter @xiaobaitu/db prisma generate",
    "prisma:migrate": "pnpm --filter @xiaobaitu/db prisma migrate dev",
    "prisma:migrate:deploy": "pnpm --filter @xiaobaitu/db prisma migrate deploy",
    "prisma:seed:system": "pnpm --filter @xiaobaitu/db seed:system",
    "deploy:db": "pnpm --filter @xiaobaitu/db deploy:v1",
    "prisma:studio": "pnpm --filter @xiaobaitu/db prisma studio"
  }
}
