# ==================== TEMU AI Studio V1.0.0 配置文件 ====================
# 复制此文件为 .env 并修改配置

# ==================== 基础配置 ====================
# 应用端口
APP_PORT=8501

# ==================== 团队版基础设施（Zeabur/云托管推荐） ====================
# Zeabur 托管 PostgreSQL 连接串
DATABASE_URL=

# Zeabur 托管 Redis 连接串
REDIS_URL=

# 启动时自动执行 Alembic 迁移（团队版推荐）
PLATFORM_AUTO_MIGRATE=true

# 启动时自动创建默认组织与组织钱包
PLATFORM_SEED_DEFAULTS=true

# 默认组织名称（后续会作为共享工作区）
PLATFORM_DEFAULT_ORG_NAME=TEMU Team Workspace

# 预留给后续个人 Key 托管 / 敏感字段加密
PLATFORM_ENCRYPTION_KEY=

# ==================== API Key 配置 ====================
# Google Gemini API Key（可选，也可在管理后台配置）
# 获取地址: https://aistudio.google.com/apikey
GOOGLE_API_KEY=
# 或使用
GEMINI_API_KEY=
# 或使用 Vertex AI Express Mode Key（如 AQ...）
GOOGLE_GENAI_USE_VERTEXAI=false

# 系统固定 API Keys（推荐线上）
# 支持逗号/分号/换行分隔多个 Key
# 示例: SYSTEM_API_KEYS_FIXED=AIzaxxx,AIzayyy 或 SYSTEM_API_KEYS_FIXED=AQ.xxxxx
SYSTEM_API_KEYS_FIXED=
# 同步策略: if_empty（仅首次注入）/ merge（合并）/ replace（每次重启覆盖）
SYSTEM_API_KEYS_SYNC_MODE=if_empty

# ==================== 认证启动注入（可选） ====================
# 固定管理员/用户密码，重启后自动注入到 settings
ADMIN_PASSWORD_FIXED=
USER_PASSWORD_FIXED=
# 是否允许系统服务普通用户免密登录（true/false）
ALLOW_PASSWORDLESS_USER_LOGIN=false

# ==================== 文件存储配置 ====================
# 存储类型: local（本地）, s3（对象存储）
FILE_STORAGE_TYPE=local

# 文件保留天数（0表示永久，建议7-30天）
FILE_RETENTION_DAYS=7

# 本地存储路径
FILE_STORAGE_PATH=/app/data/files

# ==================== S3/对象存储配置（可选） ====================
# 支持 AWS S3、阿里云 OSS、腾讯云 COS、MinIO 等
S3_ENDPOINT=
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_PREFIX=temu-files/
S3_PRESIGN_EXPIRES=86400

# ==================== 备份导出（可选） ====================
# 备份脚本上传目标；未配置则只导出到本地目录
BACKUP_S3_BUCKET=
BACKUP_S3_PREFIX=temu-backups/

# ==================== 说明 ====================
# 1. 首次部署可以不配置 API Key，在管理后台初始化
# 1.1 团队版建议直接配置 DATABASE_URL / REDIS_URL / 对象存储
# 2. 默认密码：
#    - 用户密码: eee666
#    - 管理员密码: joolhome@2023
# 3. 首次登录后建议立即修改密码
