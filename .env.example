# 电商出图工作台示例配置
# 复制为 .env 后按需修改

# 运行模式: desktop / server
APP_RUNTIME=server

# 对外端口
APP_PORT=8501

# 如果 providers.json 为空，首次启动可用以下任意一个 Key 自动创建默认 Gemini 提供商
GOOGLE_API_KEY=
GEMINI_API_KEY=

# 运行时数据目录
# Linux / Docker 建议保留 /app/data
ECOMMERCE_WORKBENCH_DATA_DIR=/app/data

# 项目输出目录
# server 版默认写入服务器项目中心
ECOMMERCE_WORKBENCH_PROJECTS_DIR=/app/data/projects

# 文件存储配置
FILE_STORAGE_TYPE=local
FILE_RETENTION_DAYS=7
FILE_STORAGE_PATH=/app/data/files

# S3 / 对象存储，可选
S3_ENDPOINT=
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_PREFIX=temu-files/
S3_PRESIGN_EXPIRES=86400

# 说明
# 1. server 版结果会先进入服务器项目中心，用户再通过浏览器下载
# 2. desktop 版允许打开本地文件夹和自定义本地保存目录
# 3. server 版不依赖 macOS Keychain

